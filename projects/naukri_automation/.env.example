# Naukri Credentials
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_password

# Job Preferences
JOB_KEYWORDS="Python Developer,Full Stack Developer,Data Scientist"
JOB_LOCATION="Bangalore"
EXCLUDE_KEYWORDS="senior,lead,manager,director,principal"
MAX_APPLICATIONS=10

# Browser Settings
HEADLESS=false
USER_DATA_DIR=./browser_data
TIMEOUT=30000

# Database
DB_PATH=db/jobs_history.db

# Notifications
NOTIFICATIONS_ENABLED=true

# Report Settings
REPORT_DIR=./reports
SAVE_REPORTS=true

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs